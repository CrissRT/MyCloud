{
  "name": "server",
  "version": "0.0.1",
  "type": "module",
  "description": "The backend server for the application",
  "scripts": {
    "build": "npx tsc",
    "start": "node dist/app.js",
    "dev": "tsx watch src/app.ts",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:rm-volumes": "docker compose down --volumes",
    "prisma:init": "npx prisma init",
    "prisma:db-pull": "npx prisma db pull",
    "prisma:generate": "npx prisma generate"
  },
  "keywords": [],
  "author": "Rotari Cristian",
  "license": "ISC",
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "@zodios/core": "^10.9.6",
    "@zodios/express": "^10.6.1",
    "@zodios/openapi": "^10.5.0",
    "axios": "^1.9.0",
    "bcryptjs": "^3.0.2",
    "check-disk-space": "^3.4.0",
    "cookie": "^1.0.2",
    "dayjs": "^1.11.13",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "i18next": "^25.2.1",
    "i18next-fs-backend": "^2.6.0",
    "i18next-http-middleware": "^3.7.4",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.56",
    "zod-i18n-map": "^2.27.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.2",
    "@types/node": "22.15.24",
    "@types/pg": "^8.15.4",
    "@types/swagger-ui-express": "^4.1.8",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
