{
  "compilerOptions": {
    "target": "es2023",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": ["DOM","es2023"],
    "jsx": "preserve",
    "strict": true,
    "allowJs": false,
    "isolatedModules": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["packages/shared/src/*"],
      "@client/*": ["apps/client/src/*"],
      "@server/*": ["apps/server/src/*"],
    },
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": false
  }
}
